# ============================================
# Web-SSH-Manager — Environment Variables
# ============================================
# คัดลอกไฟล์นี้เป็น .env.local แล้วแก้ค่า
# cp .env.example .env.local

# Database (MongoDB/MongoDB Atlas)
# สมัครฟรี: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb://localhost:27017/ssh-server

# JWT Secret — สุ่มอย่างน้อย 32 ตัวอักษร
# สร้างได้: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_change_this

# Encryption Key — ต้อง 32 ตัวอักษรพอดี (AES-256)
# สร้างได้: openssl rand -hex 16
ENCRYPTION_KEY=12345678901234567890123456789012

# ============================================
# Deployment (สำหรับ GitHub Actions secrets)
# ============================================
# DEPLOY_HOST — IP หรือ hostname ของ VPS
# DEPLOY_USER — SSH username
# DEPLOY_SSH_KEY — SSH private key สำหรับ deploy
# MONGODB_URI — MongoDB Atlas connection string
# JWT_SECRET — JWT secret (เดียวกันกับด้านบน)
# ENCRYPTION_KEY — AES-256 key (เดียวกันกับด้านบน)
